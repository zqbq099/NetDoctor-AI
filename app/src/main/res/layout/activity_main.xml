<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/gradient_background">

    <!-- شريط علوي أنيق -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary_color"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:title="نت دكتور"
        app:titleTextColor="@android:color/white"
        app:titleCentered="true" />

    <com.google.android.gms.ads.AdView
        android:id="@+id/adView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:adSize="BANNER"
        app:adUnitId="ca-app-pub-3940256099942544/6300978111" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- بطاقة معلومات الشبكة بتصميم حديث -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡 معلومات الشبكة"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_color"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/tv_network_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌐 نوع الشبكة: --"
                        android:textSize="15sp"
                        android:padding="6dp"/>

                    <TextView
                        android:id="@+id/tv_signal_strength"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📶 قوة الإشارة: --"
                        android:textSize="15sp"
                        android:padding="6dp"/>

                    <TextView
                        android:id="@+id/tv_ip_address"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📍 عنوان IP: --"
                        android:textSize="15sp"
                        android:padding="6dp"/>

                    <TextView
                        android:id="@+id/tv_operator"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱 المشغل: --"
                        android:textSize="13sp"
                        android:padding="6dp"
                        android:textColor="#666666"/>

                    <TextView
                        android:id="@+id/tv_data_usage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📊 إجمالي الاستهلاك: --"
                        android:textSize="13sp"
                        android:padding="6dp"
                        android:textColor="#4CAF50"
                        android:textStyle="bold"/>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- الأزرار الرئيسية بتصميم متسق -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_diagnose"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔍 تشخيص الشبكة"
                android:layout_marginBottom="12dp"
                app:iconGravity="textStart"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_apn_guide"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📖 دليل إعدادات APN"
                android:layout_marginBottom="12dp"
                android:textSize="16sp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_deepseek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🤖 مساعد NetDoctor الذكي (AI)"
                android:layout_marginBottom="12dp"
                android:textSize="16sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_ai_stars"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_gemini_help"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💬 مساعدة Gemini"
                android:layout_marginBottom="12dp"
                android:textSize="16sp"
                style="@style/Widget.Material3.Button.TextButton"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_analytics"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📊 تحليلات الاستهلاك"
                android:layout_marginBottom="12dp"
                android:textSize="16sp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_firewall"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔥 الجدار الناري (Pro)"
                android:layout_marginBottom="20dp"
                android:textSize="16sp"/>

            <!-- قائمة التطبيقات -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏆 أعلى التطبيقات استهلاكاً"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:textColor="@color/primary_color"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_apps"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>

    <WebView
        android:id="@+id/geminiWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone"/>

</LinearLayout>
